# Required
XAI_API_KEY=xai-...

# Optional — increases GitHub API rate limit from 60 to 5000 req/hour
GITHUB_TOKEN=ghp_...

# Optional — how many days back to search (default: 1)
LOOKBACK_DAYS=1

# Optional — minimum relevance score to include an item (default: 2)
MIN_SCORE=2

# Optional — max items per source before ranking (default: 30)
MAX_ITEMS_PER_SOURCE=30
